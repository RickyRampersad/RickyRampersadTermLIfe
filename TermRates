    $('barLabel').textContent  = mode + ' Premium';
    $('barTotal').textContent  = fmt(period);
    $('barDaily').textContent  = fmt(monthly / 30) + ' / day';
    $('barCover').textContent  = fmtSA(sa) + ' cover';

  } else {
    const j1sex  = $('j1Sex').value;
    const j1age  = parseInt($('j1Age').value);
    const j1sa   = SA.j1;
    const j2sex  = $('j2Sex').value;
    const j2age  = parseInt($('j2Age').value);
    const j2sa   = SA.j2;
    const mode   = curModeC;

    const j1 = {
      sex: j1sex, age: j1age, sa: j1sa,
      period:  xlPeriod(j1sex, j1age, j1sa, mode),
      monthly: xlPeriod(j1sex, j1age, j1sa, 'Monthly'),
      annual:  xlAnnual(j1sex, j1age, j1sa),
    };
    const j2 = {
      sex: j2sex, age: j2age, sa: j2sa,
      period:  xlPeriod(j2sex, j2age, j2sa, mode),
      monthly: xlPeriod(j2sex, j2age, j2sa, 'Monthly'),
      annual:  xlAnnual(j2sex, j2age, j2sa),
    };

    $('coupleResult').innerHTML = buildCoupleResult(j1, j2, mode);

    $('barLabel').textContent  = 'Combined ' + mode + ' Premium';
    $('barTotal').textContent  = fmt(j1.period + j2.period);
    $('barDaily').textContent  = fmt((j1.monthly + j2.monthly) / 30) + ' / day';
    $('barCover').textContent  = fmtSA(j1sa + j2sa) + ' total cover';
  }
}

calc();
</script>
</body>
</html>
